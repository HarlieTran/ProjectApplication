@model ProjectApplication.ViewModels.EditOrderViewModel

@{
    ViewData["Title"] = $"Edit Order #{Model.Id}";
}

@await Html.PartialAsync("_Header", ViewData["Title"].ToString())

<div class="card mx-auto mt-4" style="max-width: 900px;">
    <div class="card-body">
        <h4 class="card-title mb-3">Edit Order #@Model.Id</h4>
        <p class="text-muted mb-4">
            <strong>Placed by:</strong> @Model.UserFullName (@Model.UserEmail)<br />
            <strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
        </p>

        <form asp-action="Edit" method="post">
            <input asp-for="Id" type="hidden" />

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Category</th>
                            <th>Unit Price</th>
                            <th>Quantity</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.Items.Count; i++)
                        {
                            <tr>
                                <td>
                                    @Model.Items[i].ProductName
                                    <input asp-for="Items[i].Id" type="hidden" />
                                </td>
                                <td>@Model.Items[i].Category</td>
                                <td>$@Model.Items[i].UnitPrice.ToString("0.00")</td>
                                <td>
                                    <input asp-for="Items[i].Quantity" class="form-control form-control-sm" />
                                    <span asp-validation-for="Items[i].Quantity" class="text-danger"></span>
                                </td>
                                <td class="text-end">
                                    $@Model.Items[i].Subtotal.ToString("0.00")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <div>
                    <strong>Current total:</strong>
                    <span class="text-success">$@Model.TotalAmount.ToString("0.00")</span>
                </div>
                <div>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Detail" asp-route-id="@Model.Id" class="btn btn-secondary ms-2">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
