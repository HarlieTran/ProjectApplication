@model List<Order>
@{
    ViewData["Title"] = "All Orders";
}

@await Html.PartialAsync("_Header", "All Orders")

<div class="card">
    <div class="card-body">
        <div class="mb-3">
            <h5 class="mb-1">Order History</h5>
            <p class="text-muted mb-0">All orders placed by users, with full audit trail.</p>
        </div>

        @if (!Model.Any())
        {
            <p class="text-muted text-center py-4">No orders have been placed yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Order #</th>
                            <th>Placed By</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Audit Log</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody class="align-middle text-start">
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="fw-semibold">#@order.Id</td>
                                <td>@order.User.FirstName @order.User.LastName</td>
                                <td>@order.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                                <td>@order.Items.Sum(i => i.Quantity) item(s)</td>
                                <td class="text-success fw-semibold">$@order.TotalAmount.ToString("0.00")</td>
                                <td>
                                    <small class="text-muted fst-italic">@order.AuditLog</small>
                                </td>
                                <td class="align-middle">
                                    <div class="d-flex flex-column gap-2">
                                        <a asp-action="Detail" asp-route-id="@order.Id" class="btn btn-outline-secondary btn-sm" style="min-width: 120px;">
                                            View
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@order.Id" class="btn btn-outline-warning btn-sm" style="min-width: 120px;">
                                            Edit
                                        </a>
                                        <a asp-action="DeleteConfirm" asp-route-id="@order.Id" class="btn btn-outline-danger btn-sm w-100">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>