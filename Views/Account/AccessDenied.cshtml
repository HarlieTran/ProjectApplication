@{
    ViewData["Title"] = "Access Denied";
}

@await Html.PartialAsync("_Header", "Access Denied")

<div class="d-flex justify-content-center">
    <div class="card mb-3 p-3 shadow-sm rounded text-center" style="width: 60%">
        <div class="card-body py-5">
            <h1 class="display-1 text-danger">403</h1>
            <h4 class="text-danger">You do not have permission to view this page.</h4>

            @if (User.Identity!.IsAuthenticated)
            {
                <p class="text-muted mt-3">
                    Your account does not have the required role to access this page.
                    Please contact your administrator if you believe this is a mistake.
                </p>
                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                        Go Back Home
                    </a>
                </div>
            }
            else
            {
                <p class="text-muted mt-3">
                    You need to be logged in to access this page.
                </p>
                <div class="mt-4">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">
                        Go to Login
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary ms-2">
                        Go Back Home
                    </a>
                </div>
            }
        </div>
    </div>
</div>