@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    var statusMessage = TempData["StatusMessage"] as string;
    var statusType = TempData["StatusType"] as string ?? "success";
}

@await Html.PartialAsync("_Header", "Admin Dashboard - User Management")

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert alert-@statusType alert-dismissible fade show" role="alert">
        @statusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
            <div>
                <h5 class="card-title mb-1">Registered Users</h5>
                <p class="text-muted mb-0">Manage application accounts and role access.</p>
            </div>
            <a asp-action="Create" class="btn btn-primary">
                Create User
            </a>
        </div>

        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                No users have been registered yet.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@user.FullName</div>
                                    @if (user.IsCurrentUser)
                                    {
                                        <span class="badge text-bg-secondary mt-1">Current account</span>
                                    }
                                </td>
                                <td>@user.Email</td>
                                <td>
                                    <span class="badge rounded-pill text-bg-light border">@user.Role</span>
                                </td>
                                <td>
                                    @if (user.IsLockedOut)
                                    {
                                        <span class="badge text-bg-warning">Locked</span>
                                        @if (user.LockoutEnd.HasValue)
                                        {
                                            <div class="small text-muted mt-1">
                                                Until @user.LockoutEnd.Value.LocalDateTime.ToString("MMM d, yyyy h:mm tt")
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">Active</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                                        <a asp-action="Edit"
                                           asp-route-id="@user.Id"
                                           class="btn btn-sm btn-secondary">
                                            Manage
                                        </a>
                                        <a asp-action="ResetPassword"
                                           asp-route-id="@user.Id"
                                           class="btn btn-sm btn-secondary">
                                            Reset Password
                                        </a>
                                        <form asp-action="ToggleLock" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm @(user.IsLockedOut ? "btn-success" : "btn-warning")"
                                                    @(user.IsCurrentUser ? "disabled" : null)>
                                                @(user.IsLockedOut ? "Unlock" : "Lock")
                                            </button>
                                        </form>
                                        <form asp-action="Delete" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Delete this user account? This action cannot be undone.');"
                                                    @(user.IsCurrentUser ? "disabled" : null)>
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
