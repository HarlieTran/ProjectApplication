@model List<RoleViewModel>

@{
    ViewData["Title"] = "Role Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Role Management</h2>
        <div>
            <a asp-action="CreateRole" class="btn btn-primary">Create Role</a>
            <a asp-action="AssignRole" class="btn btn-success">Assign Role to User</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        @foreach (var role in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="bi bi-shield-check"></i> @role.Name
                            </h5>
                            <span class="badge bg-light text-dark">@role.UserCount user(s)</span>
                        </div>
                    </div>
                    <div class="card-body">
                        @if (role.Users.Any())
                        {
                            <h6 class="text-muted mb-3">Users with this role:</h6>
                            <ul class="list-group list-group-flush">
                                @foreach (var user in role.Users)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span>@user.UserName</span>
                                        <form asp-action="RemoveUserFromRole" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <input type="hidden" name="roleName" value="@role.Name" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Remove @user.UserName from @role.Name role?')">
                                                <i class="bi bi-x-circle"></i> Remove
                                            </button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted mb-0">
                                <i class="bi bi-info-circle"></i> No users assigned to this role yet.
                            </p>
                        }
                    </div>
                    <div class="card-footer">
                        <a asp-action="EditRole" asp-route-id="@role.Id" class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil"></i> Edit Role
                        </a>

                        <form asp-action="DeleteRole" asp-route-id="@role.Id" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger"
                                    onclick="return confirm('Are you sure you want to delete the @role.Name role? This will only work if no users are assigned.')">
                                <i class="bi bi-trash"></i> Delete Role
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No roles found. <a asp-action="CreateRole">Create one now</a>
        </div>
    }
</div>