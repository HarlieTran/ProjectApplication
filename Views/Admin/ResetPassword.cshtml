@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

@await Html.PartialAsync("_Header", "Reset Password")

<div class="d-flex justify-content-center">
    <div class="card mb-3 p-3 h-auto" style="width: 65%">
        <div class="card-body">
            <div class="mb-4">
                <h5 class="mb-1">Reset User Password</h5>
                <p class="text-muted mb-0">
                    Set a new password for this user account.
                </p>
            </div>

            <div class="alert alert-light border">
                <div><strong>User:</strong> @Model.FullName</div>
                <div><strong>Email:</strong> @Model.Email</div>
            </div>

            <form asp-action="ResetPassword" method="post">
                <input asp-for="Id" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" class="form-control" placeholder="Min. 8 characters" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat new password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary">Reset Password</button>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary ms-2">Back to User</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
